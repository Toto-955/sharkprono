    <script>
        // ===== PARTICULES =====
        function createParticles() {
            const container = document.getElementById('particles');
            for (let i = 0; i < 40; i++) {
                const p = document.createElement('div');
                p.className = 'particle';
                p.style.left = Math.random() * 100 + '%';
                p.style.animationDelay = Math.random() * 12 + 's';
                p.style.animationDuration = (8 + Math.random() * 8) + 's';
                container.appendChild(p);
            }
        }
        createParticles();

        // ===== CGU =====
        function acceptCGU() {
            document.getElementById('cguModal').style.display = 'none';
            localStorage.setItem('cguAccepted', 'true');
        }
        if (localStorage.getItem('cguAccepted')) {
            document.getElementById('cguModal').style.display = 'none';
        }

        // ===== LIENS TELEGRAM =====
        const TELEGRAM_LINKS = {
            free: 'https://t.me/totomagicien_free',
            basic: 'https://t.me/totomagicien_basic',
            tennis: 'https://t.me/totomagicien_tennis',
            rare: 'https://t.me/totomagicien_rare',
            alpha: 'https://t.me/totomagicien_alpha'
        };

        // ===== RIPPLE EFFECT =====
        function addRipple(e) {
            const btn = e.currentTarget;
            const ripple = document.createElement('span');
            ripple.className = 'ripple';
            
            const rect = btn.getBoundingClientRect();
            const size = Math.max(rect.width, rect.height);
            ripple.style.width = ripple.style.height = size + 'px';
            ripple.style.left = (e.clientX - rect.left - size/2) + 'px';
            ripple.style.top = (e.clientY - rect.top - size/2) + 'px';
            
            btn.appendChild(ripple);
            setTimeout(() => ripple.remove(), 600);
        }

        // ===== GESTION PACKS =====
        function handlePackClick(e, packType) {
            e.preventDefault();
            addRipple(e);
            
            if (packType === 'ebook') {
                alert('📚 Ebooks inclus dans Rare & Alpha VIP !');
                return;
            }

            const link = TELEGRAM_LINKS[packType];
            
            if (packType === 'free') {
                if (localStorage.getItem('pack_free_used')) {
                    alert('❌ Tu as déjà utilisé ton essai gratuit !');
                    return;
                }
                window.open(link, '_blank');
                localStorage.setItem('pack_free_used', 'true');
                return;
            }

            // Simulation paiement
            alert('💳 Redirection paiement : ' + packType.toUpperCase() + '\n\nAprès paiement → Telegram VIP');
            
            setTimeout(() => {
                const expiry = new Date();
                expiry.setDate(expiry.getDate() + 30);
                
                localStorage.setItem('active_pack', packType);
                localStorage.setItem('pack_expiry', expiry.toISOString());
                
                window.open(link, '_blank');
                startTimer(packType, expiry);
            }, 800);
        }

        // ===== TIMER =====
        function startTimer(packType, expiryDate) {
            const box = document.getElementById('timer-' + packType);
            const el = document.getElementById('countdown-' + packType);
            if (!box || !el) return;
            
            box.classList.add('active');

            function update() {
                const now = new Date();
                const diff = expiryDate - now;

                if (diff <= 0) {
                    el.innerHTML = '⛔ EXPIRÉ';
                    el.style.color = '#ff0040';
                    localStorage.removeItem('active_pack');
                    localStorage.removeItem('pack_expiry');
                    return;
                }

                const d = Math.floor(diff / 86400000);
                const h = Math.floor((diff % 86400000) / 3600000);
                const m = Math.floor((diff % 3600000) / 60000);
                el.innerHTML = `${d}j ${h}h ${m}m`;
            }

            update();
            setInterval(update, 60000);
        }

        // ===== CHECK ACTIF =====
        function checkActivePack() {
            const pack = localStorage.getItem('active_pack');
            const exp = localStorage.getItem('pack_expiry');
            if (pack && exp) {
                const date = new Date(exp);
                if (new Date() < date) startTimer(pack, date);
            }
        }
        checkActivePack();

        // ===== COMPTEURS ANIMÉS =====
        function animateCounters() {
            const counters = document.querySelectorAll('.stat-number-big');
            
            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        const el = entry.target;
                        const target = parseInt(el.getAttribute('data-target'));
                        const duration = 2000;
                        const step = target / (duration / 16);
                        let current = 0;
                        
                        const timer = setInterval(() => {
                            current += step;
                            if (current >= target) {
                                el.textContent = target;
                                clearInterval(timer);
                            } else {
                                el.textContent = Math.floor(current);
                            }
                        }, 16);
                        
                        observer.unobserve(el);
                    }
                });
            }, { threshold: 0.5 });

            counters.forEach(c => observer.observe(c));
        }
        animateCounters();

        // ===== SCROLL ANIMATIONS =====
        const fadeObserver = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.style.opacity = '1';
                    entry.target.style.transform = 'translateY(0)';
                }
            });
        }, { threshold: 0.1 });

        document.querySelectorAll('.fade-in').forEach(el => fadeObserver.observe(el));

        // ===== 3D CARDS =====
        document.querySelectorAll('.pack-card').forEach(card => {
            card.addEventListener('mousemove', (e) => {
                const rect = card.getBoundingClientRect();
                const x = e.clientX - rect.left;
                const y = e.clientY - rect.top;
                const cx = rect.width / 2;
                const cy = rect.height / 2;
                const rx = (y - cy) / 20;
                const ry = (cx - x) / 20;
                card.style.transform = `perspective(1000px) rotateX(${rx}deg) rotateY(${ry}deg) translateY(-12px) scale(1.02)`;
            });
            
            card.addEventListener('mouseleave', () => {
                card.style.transform = '';
            });
        });
    </script>

